        {
            "name": "estebanforge/hyperblocks",
            "version": "1.1.3",
            "version_normalized": "1.1.3.0",
            "dist": {
                "type": "path",
                "url": "../HyperBlocks",
                "reference": "10c4b361d48f8c4ad3c8afe878cc079569af6d4c"
            },
            "require": {
                "automattic/jetpack-autoloader": "^2",
                "estebanforge/hyperfields": "^1",
                "php": ">=8.1"
            },
            "require-dev": {
                "brain/monkey": "^2",
                "friendsofphp/php-cs-fixer": "^3",
                "mockery/mockery": "^1",
                "pestphp/pest": "^4",
                "phpunit/phpunit": "^12",
                "squizlabs/php_codesniffer": "^3"
            },
            "type": "library",
            "extra": {
                "branch-alias": {
                    "dev-main": "1.0-dev"
                }
            },
            "installation-source": "dist",
            "autoload": {
                "psr-4": {
                    "HyperBlocks\\": "src/"
                },
                "files": [
                    "bootstrap.php",
                    "src/helpers.php"
                ]
            },
            "autoload-dev": {
                "classmap": [
                    "tests/Unit/"
                ]
            },
            "scripts": {
                "test": [
                    "bash -lc 'if [ ! -f vendor/bin/pest ]; then composer update --no-interaction --no-progress; fi; php -d pcov.enabled=1 vendor/bin/pest --configuration phpunit.xml --colors=always'"
                ],
                "test:unit": [
                    "php -d pcov.enabled=1 vendor/bin/pest --configuration phpunit.xml tests/Unit --colors=always"
                ],
                "test:integration": [
                    "php -d pcov.enabled=1 vendor/bin/pest --configuration phpunit.xml tests/Integration --colors=always"
                ],
                "test:coverage": [
                    "php -d pcov.enabled=1 vendor/bin/pest --configuration phpunit.xml --coverage-html coverage-html --coverage-text"
                ],
                "cs:fix": [
                    "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php"
                ],
                "cs:check": [
                    "vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff"
                ],
                "cs:sniff": [
                    "vendor/bin/phpcs --standard=PSR12 src/"
                ],
                "version-bump": [
                    "bash scripts/version-bump.sh"
                ],
                "production": [
                    "@php composer install --no-dev --optimize-autoloader"
                ]
            },
            "license": [
                "GPL-2.0-or-later"
            ],
            "authors": [
                {
                    "name": "Esteban Cuevas",
                    "email": "esteban@actitud.xyz",
                    "homepage": "https://github.com/EstebanForge"
                }
            ],
            "description": "HyperBlocks: A powerful block library for WordPress with fluent API and field integration.",
            "keywords": [
                "blocks",
                "fields",
                "fluent-api",
                "gutenberg",
                "wordpress"
            ],
            "support": {
                "issues": "https://github.com/EstebanForge/HyperBlocks/issues",
                "source": "https://github.com/EstebanForge/HyperBlocks",
                "docs": "https://github.com/EstebanForge/HyperBlocks/blob/main/docs/"
            },
            "transport-options": {
                "symlink": false,
                "relative": true
            },
            "install-path": "../estebanforge/hyperblocks"
        },
